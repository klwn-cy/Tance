  "data_source": "CBECS 2012 (2012_public_use_data_aug2016.csv)",
  "summary": "分析商业建筑照明系统的能耗构成和节能改造潜力。",
  "key_findings": [
    {
      "finding": "照明能耗占比",
      "value": "总用电量的15-25%",
      "description": "照明是商业建筑第二大用电项，仅次于暖通空调"
    },
    {
      "finding": "主要灯具类型",
      "value": "荧光灯为主",
      "description": "2012年数据中，荧光灯仍是主流，LED正在快速增长"
    },
    {
      "finding": "节能潜力",
      "value": "30-60%",
      "description": "通过LED替换和智能控制可实现30-60%的照明节能"
    },
    {
      "finding": "控制策略",
      "value": "占用感应+日光调光",
      "description": "结合占用感应和日光采集的智能控制效果最佳"
    }
  ],
