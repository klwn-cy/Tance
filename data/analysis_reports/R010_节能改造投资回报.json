  "summary": "基于CBECS数据分析各类节能改造措施的投资回报和经济性。",
  "key_findings": [
    {
      "finding": "最佳投资回报",
      "value": "照明改造",
      "description": "LED照明改造投资回报期最短，通常1-3年即可收回投资"
    },
    {
      "finding": "中等投资回报",
      "value": "HVAC升级",
      "description": "HVAC系统升级投资回报期3-7年，节能效果显著"
    },
    {
      "finding": "长期投资",
      "value": "围护结构改造",
      "description": "围护结构改造投资大、回报期长（7-15年），但寿命长"
    },
    {
      "finding": "综合改造",
      "value": "效果最佳",
      "description": "综合节能改造可实现30-50%节能，整体经济性最优"
    }
  ],
